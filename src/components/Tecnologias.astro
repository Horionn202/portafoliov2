<style>
  .tech-section {
    width: 100%;
    overflow: visible;
    height: 520px;
    background: #0a0a0a;
    position: relative;
    z-index: 10;
  }

  .bands-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .band {
    position: absolute;
    left: -15%;
    width: 130%;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 20px 0;
  }

  .band:nth-child(1) {
    top: 60px;
    transform: rotate(-6deg);
  }

  .band:nth-child(2) {
    top: 210px;
    transform: rotate(6deg);
  }

  .band:nth-child(3) {
    top: 360px;
    transform: rotate(-6deg);
  }

  .carousel-row {
    display: flex;
    align-items: center;
    gap: 56px;
    width: max-content;
    will-change: transform;
    padding: 0 28px;
  }

  .tech-logo {
    width: 72px;
    height: 72px;
    object-fit: contain;
    flex-shrink: 0;
    opacity: 0.8;
    transition: opacity 0.3s ease, transform 0.3s ease;
    cursor: default;
    user-select: none;
  }

  .tech-logo:hover {
    opacity: 1;
    transform: scale(1.2);
    filter: drop-shadow(0 0 14px rgba(255, 255, 255, 0.4));
  }

  .tech-logo.invert {
    filter: invert(1);
  }
  .tech-logo.invert:hover {
    filter: invert(1) drop-shadow(0 0 14px rgba(255, 255, 255, 0.4));
  }
</style>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script is:inline>
  (function () {
    function initCarousel() {
      var rows = document.querySelectorAll(".carousel-row");
      rows.forEach(function (row) {
        row.innerHTML += row.innerHTML;
        var totalWidth = row.scrollWidth / 2;
        var isReverse = row.classList.contains("reverse");
        if (isReverse) gsap.set(row, { x: -totalWidth });
        var tween = gsap.to(row, {
          x: isReverse ? 0 : -totalWidth,
          duration: 32,
          ease: "none",
          repeat: -1,
        });
        row.addEventListener("mouseenter", function () { tween.timeScale(0.2); });
        row.addEventListener("mouseleave", function () { tween.timeScale(1); });
      });
    }
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initCarousel);
    } else {
      initCarousel();
    }
  })();
</script>
